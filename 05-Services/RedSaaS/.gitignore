# 敏感設定
# .env 已納入 git 備份（token 為本地 DefectDojo，無外網風險）
# 重裝後需更新 DD_TOKEN 為新 DefectDojo 實例的 token

# Python 虛擬環境
.venv/
__pycache__/
*.pyc
*.pyo

# 報告輸出（含掃描結果，可能含目標資訊）
reports/
lab/scans/

# 暫存掃描輸出
/tmp/

# nuclei-templates（太大，用 docker 動態拉）
lab/nuclei-templates/

# Docker 本地 override（若有的話）
lab/docker/.env
lab/docker/docker-compose.override.yml
