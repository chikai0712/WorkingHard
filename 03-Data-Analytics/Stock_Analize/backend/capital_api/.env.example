# 群益證券帳號密碼
CAPITAL_ACCOUNT=你的群益帳號
CAPITAL_PASSWORD=你的群益密碼

# Telegram Bot 設定
# 1. 到 Telegram 搜尋 @BotFather，建立 Bot 取得 Token
# 2. 到 @userinfobot 取得你的 Chat ID
TELEGRAM_BOT_TOKEN=你的BotToken
TELEGRAM_CHAT_ID=你的ChatID

# 趨勢線圖定時推播間隔（分鐘，0=停用）
CHART_INTERVAL_MINUTES=30

# GEM 框型突破偵測設定
GEM_LOOKBACK_BARS=60       # 回溯幾根K棒找震盪區間（預設 60）
GEM_BREAKOUT_BUFFER=0.002  # 突破確認緩衝比例（預設 0.2%）
GEM_SL_OFFSET=20           # 停損在支撐/阻力外加的點數（預設 20）
GEM_COOLDOWN_MINUTES=15    # 同方向突破最短推播間隔（分鐘，預設 15）
