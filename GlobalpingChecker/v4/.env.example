# GlobalpingChecker V4 Configuration
# Copy this file to .env and fill in your values

# PostgreSQL Database
DATABASE_URL=postgresql://globalping:your_password@localhost:5432/globalping_db

# Globalping API
GLOBALPING_TOKEN=your_globalping_token_here

# Scheduler Settings
CHECK_INTERVAL_MINUTES=90
DOMAINS_FILE=domains.txt

# Web Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# AWS Settings (for deployment)
AWS_REGION=ap-southeast-1
