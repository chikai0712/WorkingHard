# GlobalpingChecker V4.1 Configuration

# PostgreSQL
POSTGRES_PASSWORD=your_secure_password

# Globalping API
GLOBALPING_TOKEN=your_globalping_token

# Scheduler Settings
CHECK_INTERVAL_MINUTES=90
ABNORMAL_CHECK_HOUR=1      # AM 1:00 開始異常區檢測
NORMAL_CHECK_HOUR=9        # AM 9:00 開始正常區檢測
MAX_ITERATIONS=10          # 第一循環最大檢測次數
