# GlobalpingChecker V5 - 環境變數範本
# 複製此檔案為 .env 並填入實際值

# ── 資料庫 ────────────────────────────────────────────────────
DATABASE_URL=postgresql://globalping:your_password@postgres:5432/globalping_v5_db
# SQLite 本地測試用（取消以下注解）：
# DATABASE_URL=sqlite:///./data/globalping_v5.db

# ── Globalping API ────────────────────────────────────────────
GLOBALPING_TOKEN=your_globalping_token_here

# ── 目標國家開關（true / false）──────────────────────────────
ENABLE_INDONESIA=true
ENABLE_VIETNAM=false
ENABLE_THAILAND=false
ENABLE_MALAYSIA=false
ENABLE_PHILIPPINES=false
ENABLE_SINGAPORE=false

# ── 排程設定 ──────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=90
ABNORMAL_CHECK_HOUR=1
NORMAL_CHECK_HOUR=9
MAX_ITERATIONS=10
NORMAL_ZONE_RESET_HOUR=0   # AM 00:01 正常區全量重置（每日），設 -1 可停用

# ── 節點池設定 ────────────────────────────────────────────────
NODE_POOL_TTL_HOURS=24
NODE_POOL_REFRESH_HOUR=3
NODES_PER_COUNTRY=5

# ── API 額度警戒線 ────────────────────────────────────────────
API_QUOTA_WARNING_THRESHOLD=50
API_QUOTA_WAIT_ON_ERROR=3600

# ── Telegram 告警（選填）────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_ON_ZONE_CHANGE=true
TELEGRAM_NOTIFY_ON_API_ERROR=true
TELEGRAM_NOTIFY_ON_CYCLE_COMPLETE=false

# ── PostgreSQL（docker-compose 使用）────────────────────────
POSTGRES_PASSWORD=your_secure_password_here

# ── Web Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
