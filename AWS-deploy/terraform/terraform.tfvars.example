# Terraform 變數配置範例
# 複製此檔案為 terraform.tfvars 並修改以下值

# 您的域名
domain_name = "example.com"

# AWS 區域（建議選擇離您用戶最近的區域）
aws_region = "ap-northeast-1"  # 東京
# aws_region = "us-west-2"      # 美國西部
# aws_region = "eu-west-1"      # 愛爾蘭

# 環境
environment = "production"

# CloudFront 價格等級
# PriceClass_100: 美國、加拿大、歐洲（最便宜）
# PriceClass_200: 上述 + 亞洲、中東、非洲
# PriceClass_All: 全球所有節點（最貴但最快）
cloudfront_price_class = "PriceClass_200"
