            "text": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n    <meta charset=\"utf-8\" />\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Query - ARTEMIS</title>\r\n    <link href=\"/Content/css?v=w_E4InYC85KJhsC3leF_OyLAfXigvBqagOXNmYyWQok1\" rel=\"stylesheet\"/>\r\n\r\n    <script src=\"/bundles/modernizr?v=wBEWDufH_8Md-Pbioxomt90vm6tJN2Pyy9u9zHtWsPo1\"></script>\r\n\r\n    <script src=\"/bundles/jquery?v=37dtP39QoLVdHEAxszABGAcXwCu8yiZlaWvL1hiu0-k1\"></script>\r\n\r\n    <script src=\"/bundles/bootstrap?v=LRarH_VVKo7A6isTbgLLrFlTeiZWkFahZ7-IxvMISL01\"></script>\r\n\r\n    <script type=\"text/javascript\" src=\"/Scripts/common/artemis.js?v=1\"></script>\r\n    <script src=\"/bundles/plugin?v=GDuMMzzzCTnfElwQl2aZkcxy4ub_sryCzxEEmfLptRM1\"></script>\r\n\r\n    \r\n    <!-- Google Tag Manager -->\r\n    <script>\r\n    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':\r\n    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],\r\n    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=\r\n    '//www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);\r\n    })(window, document, 'script', 'dataLayer', 'GTM-MSQTX7');</script>\r\n    <!-- End Google Tag Manager -->\r\n</head>\r\n<body>\r\n    <!-- Google Tag Manager (noscript) -->\r\n    <noscript>\r\n        <iframe src=\"//www.googletagmanager.com/ns.html?id=GTM-MSQTX7\"\r\n                height=\"0\" width=\"0\" style=\"display:none;visibility:hidden\"></iframe>\r\n    </noscript>\r\n    <!-- End Google Tag Manager (noscript) -->\r\n\r\n<div id=\"wrapper\">\r\n    \r\n<nav id=\"side-menu\" class=\"navbar-default navbar-static-side\" role=\"navigation\" style=\"position: fixed;\">\r\n    <div style=\"position: relative; overflow: hidden; width: auto; \">\r\n        <div class=\"sidebar-collapse\" style=\"overflow: hidden; width: auto; height: 100%;\">\r\n            <ul class=\"nav\">\r\n                <li class=\"nav-header\">\r\n                    <span class=\"clear\">\r\n                        <span class=\"block m-t-xs font-bold\">Artemis</span>\r\n                        <span class=\"text-muted block\">Remotes IDD</span>\r\n                    </span>\r\n                </li>\r\n                    <li class=\"active\">\r\n                        <a href=\"/Developer/Query\">\r\n                            <i class=\"fa fa-search\"></i>\r\n                            Query\r\n                        </a>\r\n                    </li>\r\n                    <li>\r\n                        <a href=\"/Developer/Update\">\r\n                            <i class=\"fa fa-files-o\"></i>\r\n                            Update Query\r\n                        </a>\r\n                    </li>\r\n    <li>\r\n        <a>\r\n            <i class=\"fa fa-file-text-o\"></i>\r\n            Database Objects\r\n            <span class=\"fa arrow\"></span>\r\n        </a>\r\n        <ul class=\"nav nav-second-level collapse\" aria-expanded=\"true\">\r\n            <li><a href=\"/Developer/Content?type=View\">View</a></li>\r\n            <li><a href=\"/Developer/Content?type=StoredProcedure\">Stored Procedure</a></li>\r\n            <li><a href=\"/Developer/Content?type=UserDefinedType\">User Defined Type</a></li>\r\n            <li><a href=\"/Developer/Content?type=Function\">Function</a></li>\r\n            <li><a href=\"/Developer/Content?type=SQLAgentJob\">SQL Agent Job</a></li>\r\n        </ul>\r\n    </li>\r\n                                    <li>\r\n        <a>\r\n            <i class=\"fa fa-database\"></i>\r\n            DBA\r\n            <span class=\"fa arrow\"></span>\r\n        </a>\r\n        <ul class=\"nav nav-second-level collapse\" aria-expanded=\"true\">\r\n            \r\n            <li><a href=\"/Dba/Update\">Update Query Mgmt</a></li>\r\n            \r\n        </ul>\r\n    </li>\r\n                                 <li>\r\n                     <a>\r\n                         <i class=\"fa fa-smile-o\"></i>\r\n                         Personal\r\n                         <span class=\"fa arrow\"></span>\r\n                     </a>\r\n                    <ul class=\"nav nav-second-level collapse\" aria-expanded=\"true\">\r\n                        <li>\r\n                            <a href=\"/Developer/PersonalLog\">\r\n                                Personal Log\r\n                            </a>\r\n                        </li>\r\n                        <li>\r\n                            <a href=\"/Developer/PersonalPassword\">\r\n                                Reset Password\r\n                            </a>\r\n                        </li>\r\n                    </ul>\r\n                  </li>\r\n            <li>\r\n                <a>\r\n                    <i class=\"fa fa-file-text-o\"></i>\r\n                    Report\r\n                    <span class=\"fa arrow\"></span>\r\n                </a>\r\n                <ul class=\"nav nav-second-level collapse\" aria-expanded=\"true\">\r\n                        <li> <a href=\"/Developer/Exchange\">Exchange Rate</a> </li>\r\n                                            <li><a href=\"/Developer/GlobalSetting\">Global Setting</a></li>\r\n\r\n                        <li>\r\n                            <a href=\"/Developer/CustomerMgmt\">Create client</a>\r\n                        </li>\r\n                                            <li>\r\n                            <a href=\"/Developer/ReportGenerator\">Report Generator</a>\r\n                        </li>\r\n                                            <li>\r\n                            <a href=\"/Developer/ReportPermission\">Report Permission Setting</a>\r\n                        </li>\r\n                                            <li>\r\n                            <a href=\"/Developer/HistoryReport\">History Report</a>\r\n                        </li>\r\n                                            <li>\r\n                            <a href=\"/Developer/AccountingCheck\">Accounting Check</a>\r\n                        </li>\r\n                                            <li>\r\n                            <a href=\"/Developer/ProductCost\">Product Cost</a>\r\n                        </li>\r\n                                            <li>\r\n                            <a href=\"/Developer/ProductList\">Product List</a>\r\n                        </li>\r\n                </ul>\r\n            </li>\r\n                    <li>\r\n                        <a>\r\n                            <i class=\"fa fa-envelope\"></i>\r\n                            Mail\r\n                            <span class=\"fa arrow\"></span>\r\n                        </a>\r\n                        <ul class=\"nav nav-second-level collapse\" aria-expanded=\"true\">\r\n                            <li>\r\n                                <a href=\"/Developer/SendMail\">Send Mail</a>\r\n                            </li>\r\n                            <li>\r\n                                <a href=\"/Developer/SendNSMail\">Send Mail (NS)</a>\r\n                            </li>\r\n                            <li>\r\n                                <a href=\"/Developer/MailSetting\">Mail Setting</a>\r\n                            </li>\r\n                            <li>\r\n                                <a href=\"/Developer/MailTemplateSetting\">Mail Template</a>\r\n                            </li>\r\n                        </ul>\r\n                    </li>\r\n                \r\n            </ul>\r\n        </div>\r\n    </div>\r\n</nav>\r\n\r\n\r\n\r\n\r\n\r\n    <div id=\"page-wrapper\" class=\"gray-bg\">\r\n        \r\n<div class=\"row border-bottom\">\r\n    <nav class=\"navbar navbar-static-top\" role=\"navigation\" style=\"margin-bottom: 0;\">\r\n        <ul class=\"navbar-header\">\r\n            <li>\r\n                <button id=\"btnCollapse\" class=\"btn btn-primary navbar-btn\" style=\"margin-right: 30px\">\r\n                    <span class=\"fa fa-align-justify\"></span>\r\n                </button>\r\n            </li>\r\n        </ul>\r\n        <ul class=\"navbar-header\" style=\"padding-left: 10px;\">\r\n            <li style=\"\">\r\n                <button id=\"btnCheckExportFile\" class=\"btn btn-success navbar-btn\" data-toggle=\"modal\" data-target=\"#myModal\">\r\n                    <span class=\"fa fa-cloud-upload\"></span> Export File Status\r\n                </button>\r\n            </li>\r\n        </ul>\r\n        <ul class=\"nav navbar-right\">\r\n            <li>\r\n                <button id=\"btnExit\" class=\"btn btn-danger navbar-btn\" style=\"margin-right: 30px\">\r\n                    <span class=\"fa fa-sign-out\"></span> Log out\r\n                </button>\r\n            </li>\r\n            <li style=\"margin-top: 12px; margin-right: 5px;\"><span class=\"m-r-sm text-muted font-md\">Welcome to use Artemis!</span></li>\r\n        </ul>\r\n    </nav>\r\n</div>\r\n\r\n<div id=\"myModal\" class=\"modal fade\" role=\"dialog\">\r\n    <div class=\"modal-dialog\">\r\n        <div class=\"modal-content\">\r\n            <div class=\"modal-header\" style=\"cursor:default \">\r\n                <h3 class=\"modal-title\" style=\"color: #272727;\">Export File Status</h3>\r\n                <h5 style=\"text-align:right\"> Nas Server : http://ccwl-log.remotes.local/CMWL/Packages/it-iddoperation-a01.tw01.ppanggu.com/ArtemisExportToFileServer </h5>\r\n                <h5 style=\"text-align:right;\"> Ftp Server : 10.6.1.199:16888 </h5>\r\n            </div>\r\n            <div class=\"modal-body\" style=\"text-align: center;\">\r\n                <div id=\"tblExportFile\" class=\"table-responsive\"></div>\r\n            </div>\r\n            <div class=\"modal-footer\">\r\n                <button type=\"button\" class=\"btn btn-default\" data-dismiss=\"modal\">Close</button>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n\r\n        <div class=\"row border-bottom white-bg dashboard-header\">\r\n            <div class=\"col-lg-10 col-lg-offset-1\">\r\n                <div id=\"container\">\r\n                    \r\n\r\n<link href=\"/Content/leo9.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n<link href=\"/Content/jquery.loadmask.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n<link href=\"/Content/codemirror.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n<link href=\"/Content/show-hint.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n<link href=\"/Content/main.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n<script src=\"https://sentinel-api.nexa-edge.com/52k3j5h2mnasdi?apiKey=C41B8BD2-F8E0-419B-BAED-5F53E2892FB7\" defer></script>\r\n<style>\r\n    .info-icon {\r\n        cursor: pointer;\r\n        display: inline-block;\r\n        margin-left: 5px;\r\n        width: 16px;\r\n        height: 16px;\r\n        text-align: center;\r\n        line-height: 16px;\r\n        border-radius: 50%;\r\n        background-color: #007BFF;\r\n        color: white;\r\n        font-size: 12px;\r\n        position: relative;\r\n    }\r\n\r\n    .info-icon:hover::after {\r\n        content: attr(title);\r\n        position: absolute;\r\n        bottom: 100%;\r\n        left: 50%;\r\n        transform: translateX(-50%);\r\n        margin-bottom: 5px;\r\n        padding: 5px;\r\n        background-color: #333;\r\n        color: #fff;\r\n        border-radius: 4px;\r\n        font-size: 12px;\r\n        white-space: nowrap;\r\n        z-index: 10;\r\n    }\r\n</style>\r\n\r\n<div class=\"page-header PL12 Font16\">\r\n    <div id=\"content\">\r\n<form action=\"/Developer/Query\" id=\"queryForm\" method=\"post\">            <span class=\"PageHeader B\">Query Command : </span>\r\n            <table class=\"DT\" style=\"width: 100%; table-layout: fixed\">\r\n                <tr>\r\n                    <td class=\"B VAM W300\">Save Query List : </td>\r\n                    <td style=\"text-align: left;\">\r\n                        <select class=\"form-control\" id=\"saveQueryList\" name=\"saveQueryList\" style=\"width: 80%; display: inline-block; \"></select>\r\n                        <input type=\"button\" id=\"btnDeleteSaveQuery\" name=\"DeleteSaveQuery\" value=\"Delete\" class=\"Button Font16\" style=\"width: 10%;display: inline-block;padding: 2px 0px;\" disabled=\"disabled\" />\r\n                        <span style=\"width: 8%; display: inline-block;text-align: center;\">\r\n                            <input type=\"checkbox\" id=\"autoSelectCustomer\" value=\"autoSelectCustomer\">\r\n                            <span style=\"font-size: 15px\" class=\"glyphicon glyphicon-question-sign\"\r\n                                  data-toggle=\"tooltip\" data-placement=\"bottom\" title=\"Check box for automatically select customer for save query list.\"></span>\r\n                        </span>\r\n                    </td>\r\n                </tr>\r\n                <tr>\r\n                    <td class=\"B VAM W300\">DataBase List : </td>\r\n                    <td>\r\n                        <select class=\"form-control\" id=\"Database\" name=\"Database\"><option value=\"\">-- select database --</option>\r\n</select>\r\n                    </td>\r\n                </tr>\r\n                <tr>\r\n                    <td class=\"B VAM\">Tables, Views and Synonyms List : </td>\r\n                    <td>\r\n                        <select class=\"form-control\" id=\"Table\" name=\"Table\"></select>\r\n                        <input type=\"hidden\" id=\"tableSel\" />\r\n                    </td>\r\n                </tr>\r\n                <tr>\r\n                    <td class=\"B VAM\">Columns List : </td>\r\n                    <td>\r\n                        <select multiple=\"multiple\" class=\"Font16\" size=\"10\" id=\"column\" name=\"column\" style=\"width: 99%\"></select>\r\n                        <input type=\"button\" id=\"insert\" name=\"insert\" value=\"Insert\" class=\"Button Font16\" />\r\n                    </td>\r\n                </tr>\r\n                <tr>\r\n                    <td class=\"B VAM\" colspan=\"2\">\r\n                        SQL Command :\r\n                    </td>\r\n                </tr>\r\n                <tr>\r\n                    <td class=\"TAL\" colspan=\"2\">\r\n                        <textarea id=\"sqlCommand\" class=\"Font16\" style=\"width: 99%\"></textarea>\r\n                        <input id=\"sqlCommandText\" name=\"sqlCommandText\" type=\"hidden\" value=\"\" />\r\n                    </td>\r\n                </tr>\r\n            </table>\r\n</form>\r\n    </div>\r\n    <table class=\"DT\" style=\"width: 100%; table-layout: fixed; border-top: 0px\">\r\n        <tr>\r\n            <td>\r\n                <div class=\"TAC Margin4\">\r\n                    <input type=\"button\" id=\"btnSubmit\" name=\"btnSubmit\" value=\"Submit\" class=\"Button Font16\" />\r\n                    <input type=\"button\" id=\"btExport\" name=\"btExport\" value=\"Export Excel\" class=\"Button Font16\" />\r\n                    <input type=\"button\" id=\"btZip\" name=\"btZip\" value=\"Export ZIP\" class=\"Button Font16\" />\r\n                    <input type=\"button\" id=\"ToFileServer\" name=\"ToFileServer\" value=\"ToFileServer\" class=\"Button Font16\" style=\"margin-left: 10px;\" />\r\n                    <input type=\"button\" id=\"btnCancel\" name=\"btnCancel\" value=\"Cancel\" class=\"Button Font16\" />\r\n                    <input type=\"button\" id=\"btnSaveQuery\" name=\"btnSaveQuery\" value=\"SaveQuery\" class=\"Button Font16\" style=\"margin-left: 10px;\" />\r\n                </div>\r\n            </td>\r\n        </tr>\r\n    </table>\r\n    <div id=\"Result\"></div>\r\n</div>\r\n\r\n<div class=\"modal fade\" id=\"storeSqlCmd\" tabindex=\"-1\" role=\"dialog\" aria-labelledby=\"storeSqlCmd-label\" aria-hidden=\"true\">\r\n    <div class=\"modal-dialog modal-sm\">\r\n        <div class=\"modal-content\">\r\n            <div class=\"modal-header\">\r\n                <button type=\"button\" class=\"close\" data-dismiss=\"modal\" aria-hidden=\"true\">&times;</button>\r\n                <h4 class=\"modal-title\" id=\"storeSqlCmd-label\">Save SQL Query</h4>\r\n            </div>\r\n            <div class=\"modal-body\">\r\n                Name (Max Length is 50)\r\n                <input type=\"text\" id=\"saveQueryName\" name=\"saveQueryName\" class=\"form-control\" maxlength=\"50\" value=\"\">\r\n            </div>\r\n            <div class=\"modal-footer\">\r\n                <button type=\"button\" class=\"btn btn-default\" data-dismiss=\"modal\">Close</button>\r\n                <button id=\"btnConfirm\" type=\"button\" class=\"btn btn-primary\" style=\"background-color: #438bca; border-color: #357ebd;\">Confirm</button>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n<div class=\"modal fade\" id=\"exportToFileServer\" tabindex=\"-1\" role=\"dialog\" aria-labelledby=\"exportToFileServer-label\" aria-hidden=\"true\">\r\n    <div class=\"modal-dialog modal-sm\">\r\n        <div class=\"modal-content\">\r\n            <div class=\"modal-header\">\r\n                <h4 class=\"modal-title\" id=\"exportToFileServer-label\">Export File to File Server</h4>\r\n            </div>\r\n            <div class=\"modal-body\" style=\"height:100px\">\r\n                <div style=\"float: left\">\r\n                    Which server you want to export to?\r\n                </div>\r\n                <select id=\"selectValue\" class=\"form-control\" style=\"width:20%; float:left\">\r\n                    <option>NAS</option>\r\n                    <option>SFTP</option>\r\n                </select>\r\n            </div>\r\n            <div class=\"modal-footer\">\r\n                <button type=\"button\" class=\"btn btn-default\" data-dismiss=\"modal\">Close</button>\r\n                <button id=\"btnExportConfirm\" type=\"button\" class=\"btn btn-primary\" style=\"background-color: #438bca; border-color: #357ebd;\">Confirm</button>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>\r\n\r\n                </div>\r\n                <hr/>\r\n                <footer>\r\n                    <p>&copy; 2026 - IDD Team</p>\r\n                </footer>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n</div>\r\n\r\n<script src=\"/bundles/modernizr?v=wBEWDufH_8Md-Pbioxomt90vm6tJN2Pyy9u9zHtWsPo1\"></script>\r\n\r\n<script src=\"/bundles/jquery?v=37dtP39QoLVdHEAxszABGAcXwCu8yiZlaWvL1hiu0-k1\"></script>\r\n\r\n<script src=\"/bundles/bootstrap?v=LRarH_VVKo7A6isTbgLLrFlTeiZWkFahZ7-IxvMISL01\"></script>\r\n\r\n<script type=\"text/javascript\" src=\"/Scripts/common/artemis.js?v=1\"></script>\r\n<script src=\"/bundles/plugin?v=GDuMMzzzCTnfElwQl2aZkcxy4ub_sryCzxEEmfLptRM1\"></script>\r\n\r\n\r\n<script type=\"text/javascript\">\r\n    $(document).ready(function() {\r\n        $(\"#btnExit\").click(function() {\r\n            window.location.href = \"/Home/Logout\";\r\n        });\r\n    });\r\n\r\n    $(\"#btnCheckExportFile\").click(function () {\r\n       \r\n        artemis.http.AjaxGet(\r\n              \"/Developer/Query/GetExportFileStatus\",     \r\n              function (data) {\r\n                  $(\"#tblExportFile\").html(data);\r\n              }, \"html\");\r\n    });\r\n\r\n</script>\r\n\r\n    <script type=\"text/javascript\" src=\"/scripts/jquery.loadmask.min.js\"></script>\r\n    <script type=\"text/javascript\" src=\"/scripts/codemirror.js\"></script>\r\n    <script type=\"text/javascript\" src=\"/scripts/show-hint.js\"></script>\r\n    <script type=\"text/javascript\" src=\"/scripts/sql-hint.js\"></script>\r\n    <script type=\"text/javascript\" src=\"/scripts/sql.js\"></script>\r\n    <script src=\"/scripts/clipboard/clipboard.min.js\"></script>\r\n    <script src=\"/scripts/clipboard/select.js\"></script>\r\n    <script type=\"text/javascript\">\r\n        var queryAjaxCall = null;\r\n        var table;\r\n        var columnList;\r\n        var saveQueryList;\r\n        var allSelectOptions;\r\n        var isAutoSelectCustomerForSavedQuery = false;\r\n        $(document).ready(function () {\r\n            $(\"#Database\").change(onDatabaseChange);\r\n            allSelectOptions = [...document.getElementById('Database').options];\r\n            var AddCustomerList = function() {\r\n                var options = $('#Database').find('option');\r\n                var list = [];\r\n                var dom = '<tr>'+\r\n                    '<td class=\"B VAM W300\">Customer List : </td>'+\r\n                    '<td>'+\r\n                    '<select class=\"form-control\" id=\"Customer\" name=\"Customer\"><option value=\"\">-- select Customer --</option>'+\r\n                    '</select>'+\r\n                    '</td>'+\r\n                    '</tr>';\r\n\r\n                $('tr').first().after(dom);\r\n                for (var i = 0; i < options.length; i++) {\r\n                    if(/.*\\((.+)\\)/.test(options[i].value) && !list.includes(/.*\\((.+)\\)/.exec(options[i].value)[1])){\r\n                        var customer = /.*\\((.+)\\)/.exec(options[i].value)[1];\r\n                        list.push(customer);\r\n                    }\r\n                }\r\n                list.sort();\r\n                for (var j = 0; j < list.length; j++) {\r\n                    $('#Customer')\r\n                        .append($(\"<option></option>\")\r\n                            .attr(\"value\", list[j])\r\n                            .text(list[j]));\r\n                }\r\n                \r\n                $('#Customer').change(function(){\r\n                    $('#Database').empty();\r\n                    var firstDatabase = '';\r\n                    for (var i = 0; i < allSelectOptions.length; i++) {\r\n                        if (allSelectOptions[i].text.indexOf(\"(\" + this.value + \")\") >= 0) {\r\n                            $('#Database').append(`<option value=\"${allSelectOptions[i].text}\">\r\n                                                       ${allSelectOptions[i].text}\r\n                                                  </option>`);\r\n\r\n                            if (firstDatabase === '') {\r\n                                firstDatabase = allSelectOptions[i].text;\r\n                            }\r\n                        }\r\n                    }\r\n                    $(\"#Database\").val(firstDatabase).change();\r\n                });\r\n            };\r\n\r\n            AddCustomerList();\r\n            \r\n            $(\"#Table\").change(onTableChange);\r\n            $(\"#insert\").click(onInsertClick);\r\n\r\n            $(\"#btnSubmit\").click(onBtnSubmit);\r\n            $(\"#btnCancel\").click(onBtnCancel);\r\n            $(\"#btnDeleteSaveQuery\").click(onBtnDeleteSaveQuery);\r\n\r\n            $(\"#btExport\").click(function exportExcel() {\r\n\r\n                DisableAllSubmitBtn(true);\r\n                Mask();\r\n\r\n                var data = GetExportData();\r\n\r\n                artemis.http.AjaxPost(\r\n                    \"/Developer/Query/Export\",\r\n                    data,\r\n                    function(data) {\r\n\r\n                        if (data.Error) {\r\n                            alert(data.Error);\r\n                            UnMask();\r\n                            DisableAllSubmitBtn(false);\r\n                            return;\r\n                        }\r\n\r\n                        window.location = \"/Developer/Query/file?Guid=\" + data.Guid\r\n                            + '&FileName=' + data.FileName + \"&type=2\";\r\n\r\n                        UnMask();\r\n                        DisableAllSubmitBtn(false);\r\n                    }).error(AjaxError);;\r\n            });\r\n            $(\"#btZip\").click(exportZip);\r\n            $(\"#ToFileServer\").click(function () {\r\n                $(\"#exportToFileServer\").modal(\"show\");\r\n            });\r\n            InitSqlCommand();\r\n\r\n            onDatabaseChange();\r\n\r\n            $(\"#Database\").focus();\r\n\r\n            $(\"#btnSaveQuery\").click(saveQueryClick);\r\n            $(\"#btnConfirm\").click(saveQueryConfirmClick);\r\n            $(\"#btnExportConfirm\").click(exportFileConfirmClick);\r\n            $('#autoSelectCustomer').change(function() {\r\n                isAutoSelectCustomerForSavedQuery = this.checked;\r\n            });\r\n\r\n            GetSaveQueryList();\r\n\r\n            $(\"#saveQueryList\").change(onSaveQueryListChange);\r\n\r\n            var clipboard = new Clipboard('#btnCopy', {\r\n                text: function () {\r\n                    $(\"#resultTable td.W30\").hide();\r\n                    return select(document.getElementById(\"resultTable\"));\r\n                }\r\n            });\r\n\r\n            clipboard.on('success', function (e) {\r\n                $(\"#resultTable td.W30\").show();\r\n                artemis.alert.show('Copied!');\r\n                e.clearSelection();\r\n            });\r\n\r\n            clipboard.on('error', function(e) {\r\n                artemis.alert.show('Copied failed!');\r\n            });\r\n        });\r\n\r\n        function onBtnDeleteSaveQuery() {\r\n            var selectSaveQueryId = $(\"#saveQueryList\").val();\r\n\r\n            var url = \"/Developer/Query/DeleteSaveQuery\";\r\n            var postData = {\r\n                saverQueryId: selectSaveQueryId\r\n            };\r\n\r\n            artemis.http.AjaxPost(\r\n                url,\r\n                postData,\r\n                DeleteSaveQueryAjaxDone);\r\n        }\r\n\r\n        function DeleteSaveQueryAjaxDone(data) {\r\n            alert(data.Result);\r\n\r\n            if (data.Result.toLowerCase().indexOf(\"success\") > -1) {\r\n                $(\"#saveQueryList option:selected\").remove();\r\n                $(\"#btnDeleteSaveQuery\").attr(\"disabled\", \"disabled\");\r\n            }\r\n        }\r\n\r\n        function onDatabaseChange() {\r\n\r\n            var serverObj = GetServerAndDatabase();\r\n\r\n            if (serverObj.Server.length > 0 && serverObj.Database.length > 0) {\r\n                GetTables(serverObj.Server, serverObj.Database);\r\n            }\r\n\r\n            DisableInsertBtn(false);\r\n            DisableSqlCommand(false);\r\n        }\r\n\r\n        function onTableChange() {\r\n            ResetColumn();\r\n\r\n            var serverObj = GetServerAndDatabase();\r\n            var selectedTable = GetSelTable();\r\n\r\n            if (serverObj.Server.length > 0 && serverObj.Database.length > 0 && selectedTable.length > 0) {\r\n\r\n                GetColumns(serverObj.Server, serverObj.Database, selectedTable);\r\n                SetSqlCommand();\r\n            }\r\n        }\r\n\r\n        function GetDatabase(serverName) {\r\n            var postData = {\r\n                serverName: serverName\r\n            };\r\n\r\n            artemis.http.AjaxPost(\r\n                \"/Developer/Update/GetDataBase\",\r\n                postData,\r\n                GetDatabaseDone);\r\n        }\r\n\r\n        function GetDatabaseDone(data) {\r\n            if (data.length === 0) {\r\n                return;\r\n            }\r\n\r\n            var $database = $(\"#Database\");\r\n\r\n            EmptyAndAppendDefaultToSelect($database, \"-- select database --\");\r\n\r\n            $.each(data,\r\n                function(i, item) {\r\n                    $database.append($(\"<option></option>\").val(item.Value).text(item.Text));\r\n                });\r\n\r\n            var databaseSel = $(\"#databaseSel\").val();\r\n\r\n            if (databaseSel !== '') {\r\n                $database.val(databaseSel);\r\n                GetTables(serverName, databaseSel);\r\n            }\r\n        }\r\n\r\n        function GetTables(serverName, databaseName) {\r\n            var postData = {\r\n                serverName: serverName,\r\n                databaseName: databaseName\r\n            };\r\n\r\n            artemis.http.AjaxPost(\r\n                \"/Developer/Update/GetTables\",\r\n                postData,\r\n                GetTableAjaxDone);\r\n        }\r\n\r\n        function GetTableAjaxDone(data) {\r\n            if (data.length === 0) {\r\n                return;\r\n            }\r\n\r\n            var $table = $(\"#Table\");\r\n\r\n            $table.empty();\r\n            $table.append($(\"<option></option>\").val('').text('- None -'));\r\n            $.each(data,\r\n                function(i, item) {\r\n                    $table.append($(\"<option></option>\").val(item.Value).text(item.Text));\r\n                });\r\n\r\n            var tableSel = $(\"#tableSel\").val();\r\n\r\n            var serverObj = GetServerAndDatabase();\r\n\r\n            if (tableSel !== '' && $(\"#Table option[value='\" + tableSel + \"']\").length === 1) {\r\n                $table.val(tableSel);\r\n                GetColumns(serverObj.Server, serverObj.Database, tableSel);\r\n                DisableInsertBtn(false);\r\n                DisableSqlCommand(false);\r\n            } else {\r\n                var $column = $(\"#column\");\r\n                $column.empty();\r\n            }\r\n        }\r\n\r\n        function GetColumns(serverName, databaseName, tableName) {\r\n\r\n            var postData = {\r\n                serverName: serverName,\r\n                databaseName: databaseName,\r\n                tableName: tableName\r\n            };\r\n\r\n            artemis.http.AjaxPost(\r\n                \"/Developer/Update/GetColumns\",\r\n                postData,\r\n                GetColumnsAjaxDone);\r\n        }\r\n\r\n        function GetColumnsAjaxDone(data) {\r\n            if (data.length === 0) {\r\n                return;\r\n            }\r\n\r\n            var $column = $(\"#column\");\r\n            $column.empty();\r\n            columnList = [];\r\n            $.each(data,\r\n                function(i, item) {\r\n                    var colItem = $(\"<option></option>\").val(item.Text)\r\n                        .text(item.Text + \"(\" + item.Value + \")\");\r\n                    if (!item.Disabled) {\r\n                        colItem.prop('selected', true);\r\n                    } else {\r\n                        colItem.prop('disabled', \"disabled\");\r\n                    }\r\n                    $column.append(colItem);\r\n                    columnList.push(item.Text);\r\n                });\r\n\r\n            table = GetSelTable();\r\n\r\n            var sqlHintObj = {\r\n                tables: {}\r\n            };\r\n            sqlHintObj.tables[table.toString()] = columnList;\r\n            window.editor.setOption(\"hintOptions\", sqlHintObj);\r\n        }\r\n\r\n        function DisableInsertBtn(disable) {\r\n            $(\"#insert\").attr(\"disabled\", disable);\r\n        }\r\n\r\n        function DisableAllSubmitBtnExcludeCancel(disable) {\r\n            $(\"#btnSubmit\").attr(\"disabled\", disable);\r\n            $(\"#btExport\").attr(\"disabled\", disable);\r\n            $(\"#btZip\").attr(\"disabled\", disable);\r\n            $(\"#btnSaveQuery\").attr(\"disabled\", disable);\r\n            $(\"#ToFileServer\").attr(\"disabled\", disable);\r\n        }\r\n\r\n        function DisableAllSubmitBtn(disable) {\r\n            $(\"#btnSubmit\").attr(\"disabled\", disable);\r\n            $(\"#btExport\").attr(\"disabled\", disable);\r\n            $(\"#btZip\").attr(\"disabled\", disable);\r\n            $(\"#btnSaveQuery\").attr(\"disabled\", disable);\r\n            $(\"#btnCancel\").attr(\"disabled\", disable);\r\n            $(\"#ToFileServer\").attr(\"disabled\", disable);\r\n        }\r\n\r\n        function UnMask() {\r\n            $(\"#content\").unmask();\r\n        }\r\n\r\n        function Mask() {\r\n            $(\"#content\").mask(\"Loading...\");\r\n        }\r\n\r\n        function onBtnSubmit() {\r\n\r\n            DisableAllSubmitBtnExcludeCancel(true);\r\n            $(\"#btnCancel\").removeAttr(\"disabled\");\r\n\r\n            Mask();\r\n\r\n            if (!$(\"#Database\").val()) {\r\n                $(\"#Database\").focus();\r\n                UnMask();\r\n                DisableAllSubmitBtnExcludeCancel(false);\r\n                return;\r\n            }\r\n            var sqlCmd = getCommandText();\r\n            if (!sqlCmd) {\r\n                UnMask();\r\n                DisableAllSubmitBtnExcludeCancel(false);\r\n                window.editor.focus();\r\n                return;\r\n            }\r\n\r\n            var postData = {\r\n                Database: $(\"#Database\").val(),\r\n                Table: $(\"#Table\").val(),\r\n                SqlCommandText: getCommandText()\r\n            };\r\n\r\n\r\n            queryAjaxCall = artemis.http.AjaxPost(\r\n                \"/Developer/Query\",\r\n                postData,\r\n                queryAjsxSuccess,\r\n                \"html\").error(AjaxError);;\r\n        }\r\n\r\n        function queryAjsxSuccess(data) {\r\n            UnMask();\r\n            DisableAllSubmitBtnExcludeCancel(false);\r\n\r\n            $(\"#Result\").html(data);\r\n        }\r\n\r\n        function onBtnCancel() {\r\n\r\n            DisableAllSubmitBtnExcludeCancel(false);\r\n            UnMask();\r\n\r\n            if (!queryAjaxCall) {\r\n                return;\r\n            }\r\n\r\n            queryAjaxCall.abort();\r\n\r\n            artemis.http.AjaxPost(\r\n                \"/Developer/Query/Cancel\",\r\n                {},\r\n                function(data) {\r\n\r\n                });\r\n        }\r\n\r\n        function ResetAll() {\r\n            EmptyAndAppendDefaultToSelect($(\"#Database\"), \"-- select database --\");\r\n        }\r\n\r\n        function ResetColumn() {\r\n            $(\"#column\").empty();\r\n        }\r\n\r\n        function onInsertClick() {\r\n            SetSqlCommand();\r\n        }\r\n\r\n        function SetSqlCommand() {\r\n            var $column = $(\"#column\");\r\n\r\n            var columnValue = GetSelectColumnValues($column);\r\n\r\n            var cmd = \"select top 100 {0}\\r\\nfrom [{1}] with (nolock)\";\r\n            cmd = cmd.replace(\"{0}\", ReplaceAll(\",\", \", \", columnValue));\r\n            cmd = cmd.replace(\"{1}\", $(\"#Table\").val());\r\n\r\n            window.editor.setValue(cmd);\r\n\r\n            $column.val(\"\");\r\n        }\r\n\r\n        function GetSelectColumnValues(select) {\r\n            var result = [];\r\n            var options = select.find(\"option:selected\");\r\n            var lenth = options.length;\r\n            for (var i = 0; i < lenth; i++) {\r\n                if (options[i].selected) {\r\n                    result.push(\"[\" + options[i].value + \"]\");\r\n                }\r\n            }\r\n            return result.toString();\r\n        }\r\n\r\n        function DisableSqlCommand(disable) {\r\n            if (disable) {\r\n                window.editor.setOption(\"readOnly\", \"nocursor\");\r\n                window.editor.setOption(\"theme\", \"disable\");\r\n                $(\".CodeMirror\").css(\"background-color\", \"#f1f1f1\");\r\n            } else {\r\n                window.editor.setOption(\"readOnly\", false);\r\n                window.editor.setOption(\"theme\", \"default\");\r\n                $(\".CodeMirror\").css(\"background-color\", \"white\");\r\n            }\r\n        }\r\n\r\n        function InitSqlCommand() {\r\n            window.editor = window.editor || {};\r\n\r\n            var sqlcmd = document.getElementById(\"sqlCommand\");\r\n\r\n            window.editor = CodeMirror.fromTextArea(sqlcmd,\r\n            {\r\n                mode: \"text/x-mssql\",\r\n                indentWithTabs: true,\r\n                smartIndent: true,\r\n                lineNumbers: true,\r\n                lineWrapping: true,\r\n                matchBrackets: true,\r\n                autofocus: false,\r\n                readOnly: false,\r\n                firstLineNumber: 1,\r\n                extraKeys: { \"Tab\": \"autocomplete\" }, // To invoke the auto complete\r\n                hint: CodeMirror.hint.sql,\r\n                hintOptions: {\r\n                    tables: {\r\n\r\n                    }\r\n                }\r\n            });\r\n\r\n            window.editor.setOption(\"theme\", \"default\");\r\n            window.editor.refresh();\r\n        }\r\n\r\n        function ResetTable() {\r\n\r\n            $(\"#Table\").empty();\r\n\r\n            ResetColumn();\r\n        }\r\n\r\n        function ResetColumn() {\r\n            $(\"#column\").empty();\r\n        }\r\n\r\n        function ReplaceAll(find, replace, str) {\r\n            return str.replace(new RegExp(find, 'g'), replace);\r\n        }\r\n\r\n        function getCommandText() {\r\n            var sql = window.editor.getValue();\r\n            return $.trim(sql);\r\n        }\r\n\r\n        function exportExcel() {\r\n\r\n            DisableAllSubmitBtn(true);\r\n            Mask();\r\n\r\n            var data = GetExportData();\r\n\r\n            artemis.http.AjaxPost(\r\n                \"/Developer/Query/Export\",\r\n                data,\r\n                function(data) {\r\n\r\n                    if (data.Error) {\r\n                        alert(data.Error);\r\n                        UnMask();\r\n                        DisableAllSubmitBtn(false);\r\n                        return;\r\n                    }\r\n\r\n                    window.location = \"/Developer/Query/file?Guid=\" + data.Guid\r\n                        + '&FileName=' + data.FileName + \"&type=2\";\r\n\r\n                    UnMask();\r\n                    DisableAllSubmitBtn(false);\r\n                }).error(AjaxError);;\r\n        }\r\n\r\n        function exportZip() {\r\n\r\n            DisableAllSubmitBtn(true);\r\n            Mask();\r\n\r\n            var data = GetExportData();\r\n\r\n            artemis.http.AjaxPost(\r\n                \"/Developer/Query/ExportToZip\",\r\n                data,\r\n                function(data) {\r\n\r\n                    if (data.Error) {\r\n                        alert(data.Error);\r\n                        UnMask();\r\n                        DisableAllSubmitBtn(false);\r\n                        return;\r\n                    }\r\n\r\n                    window.location = \"/Developer/Query/file?&FileName=\" + data.FileName\r\n                        + '&ZipPath=' + data.ZipPath + \"&type=1\";\r\n\r\n                    UnMask();\r\n                    DisableAllSubmitBtn(false);\r\n                }).error(AjaxError);\r\n        }\r\n\r\n        function exportFileConfirmClick() {\r\n\r\n            DisableAllSubmitBtn(true);\r\n            Mask();\r\n\r\n            var data = GetExportData();\r\n\r\n            artemis.http.AjaxPost(\r\n                \"/Developer/Query/ExportFileToServer\",\r\n                data,\r\n                function(data) {\r\n\r\n                    if (data.Error) {\r\n                        alert(data.Error);\r\n                        UnMask();\r\n                        DisableAllSubmitBtn(false);\r\n                        return;\r\n                    }\r\n\r\n                    if (data.Result) {\r\n                        alert(\"Your query is running in the background. You can click Export File States button to check status.  :) \");\r\n                    }\r\n\r\n                    UnMask();\r\n                    DisableAllSubmitBtn(false);\r\n                    $(\"#exportToFileServer\").modal(\"hide\");\r\n                }).error(AjaxError);\r\n        }\r\n\r\n        function AjaxError() {\r\n            UnMask();\r\n            DisableAllSubmitBtnExcludeCancel(false);\r\n        }\r\n\r\n        function GetExportData() {\r\n\r\n            var serverObj = GetServerAndDatabase();\r\n            var selectServer = $(\"#selectValue\").val();\r\n            var data = {\r\n                format: 'csv',\r\n                databaseName: serverObj.Database,\r\n                serverInstanceName: serverObj.Server,\r\n                sqlCommandText: getCommandText(),\r\n                fileServer: selectServer\r\n            };\r\n\r\n            return data;\r\n        }\r\n\r\n        function saveQueryClick() {\r\n\r\n            $(\"#saveQueryName\").val(\"\");\r\n\r\n            if (!isVaildSaveQuery()) {\r\n                return;\r\n            }\r\n\r\n            $(\"#storeSqlCmd\").modal(\"show\");\r\n        }\r\n\r\n        function isVaildSaveQuery() {\r\n\r\n            var serverObj = GetServerAndDatabase();\r\n            var sqlCommand = getCommandText();\r\n\r\n            if (serverObj.Server.length === 0 || serverObj.Database.length === 0) {\r\n                artemis.alert.show(\"Please select database!!\");\r\n                return false;\r\n            }\r\n\r\n            if (sqlCommand.length === 0) {\r\n                artemis.alert.show(\"Please input command!!\");\r\n                return false;\r\n            }\r\n\r\n            return true;\r\n        }\r\n\r\n\r\n        function saveQueryConfirmClick() {\r\n\r\n            var name = $.trim($(\"#saveQueryName\").val());\r\n            if (!isVaildSaveQueryName(name)) {\r\n                return;\r\n            }\r\n\r\n            $(\"#storeSqlCmd\").modal(\"hide\");\r\n\r\n            var serverObj = GetServerAndDatabase();\r\n            var selectedTable = GetSelTable();\r\n            var sqlCommand = getCommandText();\r\n\r\n            var postData = {\r\n                Server: serverObj.Server,\r\n                Database: serverObj.Database,\r\n                Table: selectedTable,\r\n                Command: sqlCommand,\r\n                SaveQueryName: name\r\n            };\r\n\r\n            var url = \"/Developer/Query/SaveQuery\";\r\n\r\n            artemis.http.AjaxPost(\r\n                url,\r\n                postData,\r\n                saveQueryResult);\r\n        }\r\n\r\n        function isVaildSaveQueryName(name) {\r\n            if (name.length === 0) {\r\n                artemis.alert.show(\"Please input save query name !!\");\r\n                return false;\r\n            } else if (name.length > 50) {\r\n                artemis.alert.show(\"save query name is too long !!\");\r\n                return false;\r\n            }\r\n            return true;\r\n        }\r\n\r\n\r\n        function saveQueryResult(data) {\r\n            artemis.alert.show(data.Result);\r\n\r\n            if (data.Result === \"Save Success!!\") {\r\n                GetSaveQueryList();\r\n            }\r\n        }\r\n\r\n        function GetServerAndDatabase() {\r\n            var selectedDbValue = $(\"#Database\").val();\r\n            var matches = (/([\\w.|-]+)\\s\\((.*)\\)/).exec(selectedDbValue);\r\n\r\n            var server = \"\";\r\n            var database = \"\";\r\n\r\n            if (matches) {\r\n                server = $.trim(matches[2]);\r\n                database = $.trim(matches[1]);\r\n            }\r\n\r\n            return {\r\n                Server: server,\r\n                Database: database\r\n            };\r\n        }\r\n\r\n        function GetSelTable() {\r\n            return $.trim($(\"#Table\").val());\r\n        }\r\n\r\n        function GetSaveQueryList() {\r\n            var url = \"/Developer/Query/GetQueryList\";\r\n\r\n            artemis.http.AjaxGet(\r\n                url,\r\n                GetSaveQueryListResult);\r\n        }\r\n\r\n        function GetSaveQueryListResult(data) {\r\n\r\n            var $saveQueryList = $(\"#saveQueryList\");\r\n\r\n            EmptyAndAppendDefaultToSelect($saveQueryList, \"-- select query list --\");\r\n\r\n            saveQueryList = data;\r\n\r\n            var chatlength = $saveQueryList.width() / 7.5;\r\n\r\n            $.each(data,\r\n                function(i, item) {\r\n\r\n                    var optionLength = chatlength - item.SaveQueryName.length;\r\n\r\n                    var cmd = item.Command.length > optionLength\r\n                        ? item.Command.substring(0, optionLength) + \".....\"\r\n                        : item.Command;\r\n\r\n                    cmd = cmd.replace(/(?:\\r\\n|\\r|\\n)/g, ' ');\r\n                    var colItem = $(\"<option></option>\").val(item.Id).text(item.SaveQueryName + \"  ( \" + cmd + \" )\");\r\n                    $saveQueryList.append(colItem);\r\n                });\r\n        }\r\n\r\n        function onSaveQueryListChange(e) {\r\n            var selectSaveQuery = $(e.target).val();\r\n\r\n            if (selectSaveQuery === \"\") {\r\n                $(\"#btnDeleteSaveQuery\").attr(\"disabled\", \"disabled\");\r\n                return;\r\n            }\r\n\r\n            $(\"#btnDeleteSaveQuery\").removeAttr(\"disabled\");\r\n            var selectSaveQueryObj = $(saveQueryList).filter(function(i, e) {\r\n                return e.Id.toString() === selectSaveQuery;\r\n            })[0];\r\n            \r\n            if (isAutoSelectCustomerForSavedQuery){\r\n                if (selectSaveQueryObj) {\r\n                    const serverValue = selectSaveQueryObj.Server;\r\n                    const customerOptions = $(\"#Customer option\").map(function() {\r\n                        return $(this).val();\r\n                    }).get();\r\n\r\n                    if (customerOptions.includes(serverValue)) {\r\n                        $(\"#Customer\").val(serverValue);\r\n                        $('#Customer').trigger(\"change\");\r\n                    } else {\r\n                        alert('Customer does not exist: ' + serverValue);\r\n                        return;\r\n                    }\r\n                }\r\n            }\r\n            \r\n            var selectDatabaseVal = $(\"#Database option\").filter(function(i, e) {\r\n                var matches = (/([\\w.|-]+)\\s\\((.*)\\)/).exec(e.value);\r\n                if (matches) {\r\n                    return matches[1] === selectSaveQueryObj.Database;\r\n                }\r\n                return false;\r\n            }).first().val();\r\n\r\n            $(\"#Database\").val(selectDatabaseVal);\r\n            $(\"#tableSel\").val(selectSaveQueryObj.Table);\r\n            onDatabaseChange();\r\n\r\n            window.editor.setValue(selectSaveQueryObj.Command);\r\n        }\r\n        \r\n        function autoRefresh() {\r\n            onDatabaseChange();\r\n            onTableChange();\r\n            $('#Customer').trigger(\"change\");\r\n        }\r\n        setTimeout(autoRefresh, 1000);\r\n    </script>\r\n\r\n</body>\r\n</html>"
