          "content": {
            "size": 16518,
            "mimeType": "text/css",
            "compression": 11886,
            "text": "@import url(\"general.css\");\r\n/* CSS Document */\r\n/* Query Table */\r\n.QT{ border:2px solid #900; background:#FFF;}\r\n.QT caption{ font:700 12px/20px Tahoma; background:url(../images/caption_a.gif) no-repeat 2px 4px; padding:2px 0px 0px 22px; text-align:left; color:#fff;}\r\n.QT tbody th,.QT tbody td{border:1px solid #FCF; padding:2px;}\r\n.QT tbody th{ text-align:right; width:150px; vertical-align:top; line-height:22px;color:#C00;}\r\n.QT tbody td{ vertical-align:middle;}\r\n.QT tfoot td{ text-align:center;}\r\n\r\n/* Data Input Table */\r\n.DIT{ border:2px solid #900; background:#FFF;}\r\n.DIT caption,.DIT caption.MediumCaption,.DIT caption.LongCaption{ font:700 12px/20px Tahoma; padding:2px 0px 0px 22px; text-align:left; color:#fff;}\r\n.DIT caption{background:url(../images/caption_a.gif) no-repeat 2px 4px;}\r\n.DIT caption.MediumCaption{background:url(../images/caption_a2.gif) no-repeat 2px 4px;}\r\n.DIT caption.LongCaption{background:url(../images/caption_a3.gif) no-repeat 2px 4px;}\r\n.DIT thead td{ background-color:#FF9999; font:700 12px Tahoma; text-align:center;}\r\n.DIT tbody th,.DIT tbody td{border:1px solid #FCF; padding:2px;}\r\n.DIT tbody th{ text-align:right; vertical-align:top; line-height:22px;color:#C00;}\r\n.DIT tbody td{ vertical-align:middle;}\r\n.DIT tfoot td{ text-align:center;}\r\n.DIT ul{list-style:disc; margin-bottom:5px;}\r\n.DIT ul ul{list-style:circle;}\r\n.DIT ul, .DIT ul ul{padding-left:10px; margin-left:10px;}\r\n.DIT li{padding:3px;}\r\n\r\n/* Data Input Table Affiliate */\r\n.DITAFF{ border:2px solid #900; background:#FDEADA;}\r\n.DITAFF tbody th,.DITAFF tbody td{border:1px solid #FCF; padding:2px;}\r\n.DITAFF tbody th{ text-align:right; vertical-align:top; line-height:22px;color:#C00;}\r\n.DITAFF tbody td{ vertical-align:middle;}\r\n.DITAFF tfoot td{ text-align:center;}\r\n\r\n/* Data Input Table SB */\r\n.DITSB{ border:2px solid #900; background:#FFE6E6;}\r\n.DITSB tbody th,.DITSB tbody td{border:1px solid #FCF; padding:2px;}\r\n.DITSB tbody th{ text-align:right; vertical-align:top; line-height:22px;color:#C00;}\r\n.DITSB tbody td{ vertical-align:middle;}\r\n.DITSB tfoot td{ text-align:center;}\r\n\r\n/* Data Input Table RB */\r\n.DITRB{ border:2px solid #7030a0; background:#daddff;}\r\n.DITRB tbody th,.DITRB tbody td{border:1px solid #cc99ff; padding:2px;}\r\n.DITRB tbody th{ text-align:right; vertical-align:top; line-height:22px;color:#C00;}\r\n.DITRB tbody td{ vertical-align:middle;}\r\n.DITRB tfoot td{ text-align:center;}\r\n\r\n/* Data Input Table RBBT */\r\n.DITRBBT{ border:2px solid #7030a0; background:#daddff;}\r\n.DITRBBT tbody th,.DITRBBT tbody td{border:1px solid #cc99ff; padding:2px;}\r\n.DITRBBT tbody th{ text-align:right; vertical-align:top; line-height:22px;color:#C00;}\r\n.DITRBBT tbody td{ vertical-align:middle;}\r\n.DITRBBT tfoot td{ text-align:center;}\r\n\r\n/* Data Input Table GM */\r\n.DITGM{ border:2px solid #76923c; background:#edffc9;}\r\n.DITGM tbody th,.DITGM tbody td{border:1px solid #99cc99; padding:2px;}\r\n.DITGM tbody th{ text-align:right; vertical-align:top; line-height:22px;color:#C00;}\r\n.DITGM tbody td{ vertical-align:middle;}\r\n.DITGM tfoot td{ text-align:center;}\r\n\r\n/* Data Input Table RT*/\r\n.DITRT{ border:2px solid #9b5b00; background:#ffefd8;}\r\n.DITRT tbody th,.DITRT tbody td{border:1px solid #dabf97; padding:2px;}\r\n.DITRT tbody th{ text-align:right; vertical-align:top; line-height:22px;color:#C00;}\r\n.DITRT tbody td{ vertical-align:middle;}\r\n.DITRT tfoot td{ text-align:center;}\r\n\r\n/* Data Input Table LC*/\r\n.DITLC{ border:2px solid #0034aa; background:#e7efff;}\r\n.DITLC tbody th,.DITLC tbody td{border:1px solid #cddeff; padding:2px;}\r\n.DITLC tbody th{ text-align:right; vertical-align:top; line-height:22px;color:#C00;}\r\n.DITLC tbody td{ vertical-align:middle;}\r\n.DITLC tfoot td{ text-align:center;}\r\n\r\n/* Data Input Table */\r\n.DIT2{ border:0px solid #fff; background:#FFF;}\r\n.DIT2 thead td{ background-color:#FF9999; font:700 12px Tahoma; text-align:center;}\r\n.DIT2 tbody th,.DIT2 tbody td{border:1px solid #FCF; padding:2px;}\r\n.DIT2 tbody th{ text-align:right; vertical-align:top; line-height:22px;color:#C00;}\r\n.DIT2 tbody td{ vertical-align:middle;} \r\n.DIT2 tfoot td{ text-align:center;}\r\n\r\n/* Data Grid Table */\r\n.DT{ border:2px solid #900; border-collapse:collapse; text-align:center; background:#FFF; width:auto;}\r\n.DT caption,.DT caption.MediumCaption,.DT caption.LongCaption{ font:700 12px/20px Tahoma; padding:2px 0px 0px 22px; text-align:left; color:#fff;}\r\n.DT caption{background:url(../images/caption_a.gif) no-repeat 2px 4px;}\r\n.DT caption.MediumCaption{background:url(../images/caption_a2.gif) no-repeat 2px 4px;}\r\n.DT caption.LongCaption{background:url(../images/caption_a3.gif) no-repeat 2px 4px;}\r\n.DT thead td{ border:1px solid #FCF; background-color:#F99; color:#000; padding:4px; font-weight:700;}\r\n.DT tbody td,.DT tfoot td{ border:1px solid #FCF; padding:4px;}\r\n.DT a:link, .DT a:visited, .DT a:active{text-decoration:none;color:#0000FF;}\r\n\r\n/* caption*/\r\n.Caption2{background:url(../images/caption_a2.gif) no-repeat 2px 4px !important;}\r\n.Caption3{background:url(../images/caption_a3.gif) no-repeat 2px 4px !important;}\r\n.Caption4{background:url(../images/caption_a4.gif?130620) no-repeat 2px 4px !important;}\r\n\r\ncaption a:link,caption a:visited,caption a:active{ text-decoration:underline; color:#fff;}\r\ncaption a:hover{ color:#FF3;}\r\n\r\n/* background color of row */\r\n.TrOdd{background-color:#FFF;}\r\n.TrEven{background-color:#FEE;}\r\n.TrHover{background-color:#fcfc95;}\r\n.TrClosed{ background-color:#DDD;}\r\n.TrTransfer td{background-color:#E5E0EC !important;}\r\n.TrTransInactive{background-color:#e2baba;}\r\n.TrRowHighlight{background-color:#fff4d1;}\r\n.CoverBetBg td{background-color:#B4EDFF;}\r\n\r\n/* special data format */\r\n.Positive,.Plus{ color:#03F; font-weight:700;}\r\n.Negative,.Minus{ color:#F00; font-weight:700; white-space:nowrap !important;}\r\n.Input,.Button{}\r\n.Input{font:12px Tahoma;}\r\n.InputButton{background-color:#CCC; border:1px solid #CCC; margin:0px 0px 0px -4px; font:700 11px Tahoma;}\r\n.Button{border:1px solid #900; padding:2px 10px; font:700 12px Tahoma; background-color:#F99; }\r\n/* special data format */\r\n\r\n/* Data Grid Table */\r\n.RDT{ border:2px solid #418bbd; border-collapse:collapse; text-align:center; background:#FFF;}\r\n.RDT thead td{ border:1px solid #418bbd; background-color:#8bb9d7; color:#000; padding:4px 15px; font-weight:700;}\r\n.RDT tbody td,.RDT tfoot td{ border:1px solid #b5d2e5; padding:4px 15px; white-space:nowrap;}\r\n\r\n.RDTCaption{ font:700 14px/22px Tahoma; background:url(../images/icon_datatable.gif) no-repeat 2px 2px; padding-left:22px; text-align:left; color:#418bbd; width:450px; float:left; margin-top:6px;}\r\n.ExportData{width:80px; float:right; text-align:right; margin-top:8px;}\r\n\r\n/* month picker for report*/\r\n.MonthPicker{border:2px solid #418bbd; text-align:center; border-collapse:collapse;}\r\n.MonthPicker tbody td{width:40px; border:1px dotted #ccc; cursor:pointer;}\r\n.MonthPicker tbody td:Hover{ background-color:#FF9; cursor:pointer;}\r\n.MonthPicker tbody td.TdYMD{ font-weight:700; width:74px; text-align:right; padding:2px 15px;}\r\n.MonthPicker tbody td.Active{ color:#FFF; font-weight:700; background-color:#418bbd;}\r\n.MonthPicker tbody td.Active:Hover{color:#FF9;}\r\n\r\n/* special data format for report */\r\n.TrSum{ background-color:#FFC; border-bottom:2px solid #418bbd !important; border-top:2px solid #418bbd !important; height:24px; vertical-align:middle;}\r\n/*special border for LEO project*/\r\n.BLBRRed{border-right:3px double #990000 !important;border-left:3px double #990000 !important;}\r\n.BLRed{border-left:3px double #990000 !important;}\r\n.BetList{color:#69C;}\r\n.BetListTotal{color:#00F;}\r\n\r\n/*special background color for LEO project*/\r\n.BC01{background-color:#EECACA;}\r\n.BC02{background-color:#F99;}\r\n.BC03{background-color:#FC3;}/*for pt selection*/\r\n.BC04{background-color:#EEE;}/*for member search */\r\n.BC05{background-color:#FFF;}/*for member search*/\r\n.BCA{ background-color:#aeaaff;}\r\n.BCMA{ background-color:#adffad;}\r\n.BCSMA{ background-color:#8a8b01;}/*balance*/\r\n.BCAFF{background-color:#FFB97E;}/*for affilate*/\r\n.W118{width:118px;}\r\n/* Compare price, price difference*/\r\n.ValueUpdated{background:#FFE6E6 url(../images/bgvaluechanged.gif) repeat;}\r\n.ValueUpdatedAFF{background:#FDEADA url(../images/bgvaluechanged.gif) repeat;}\r\n\r\n/* PT value display*/\r\n.PTMaxVal,.PTMinVal {font-size:10px;color:#888;vertical-align: 30%;}\r\n.PTMinVal {\tvertical-align: -20%;font-weight:normal;}\r\n.PTForcedVal{vertical-align:10%;font-size:10px;color:#900;font-weight:normal;}\r\n.PTMaxVal{\tcolor:#039;}\r\n.PTBC01{background-color:#dbe5f1;}\r\n.PTBC02{background-color:#f2dcdb;}\r\n.PTBC03{background-color:#ebf1dd;}\r\n.PTBC04{background-color:#e5e0ec;}\r\n.PTBC05{background-color:#fdeada;}\r\n.BL2{border-left:2px solid #900 !important;}\r\n.BL8{border-left:8px solid #EECACA !important;}\r\n.BR2{border-right:2px solid #900 !important;}\r\n.BB2{border-bottom:2px solid #900 !important;} \r\n\r\n/* PT value display*/\r\n.ProductTab{ margin:10px 0px 0px 0px;}\r\n.ProductTab thead th{ padding:4px 10px; font:700 12px Tahoma; width:110px;}\r\n.ProductTab thead td.PList{ padding:4px 10px; font:700 12px Tahoma;}\r\n.ProductTab thead td.PSelectedSB{padding:4px 10px;background-color:#900; color:#FFF; font:700 12px Tahoma;}\r\n.ProductTab thead td.PSelectedRB{padding:4px 10px;background-color:#7030a0; color:#FFF; font:700 12px Tahoma;}\r\n.ProductTab thead td.PSelectedRBBT{padding:4px 10px;background-color:#7030a0; color:#FFF; font:700 12px Tahoma;}\r\n.ProductTab thead td.PSelectedRT{padding:4px 10px;background-color:#9b5b00; color:#FFF; font:700 12px Tahoma;}\r\n.ProductTab thead td.PSelectedGM{padding:4px 10px;background-color:#76923c; color:#FFF; font:700 12px Tahoma;}\r\n.ProductTab thead td.PSelectedLC{padding:4px 10px;background-color:#0034aa; color:#FFF; font:700 12px Tahoma;}\r\n\r\n.SectionHead{text-align:center; font-weight:700; line-height:20px;}\r\n.SectionSave{float:right;}\r\n.SectionBlackList{float:left;}\r\n\r\n/*final balance*/\r\n.ButtonNO{border:1px solid #CCC;color:#999;font:700 11px Tahoma;background-color:#FFF;height:16px;width:30px;padding:0px;}\r\n.ButtonYES{border:1px solid #900;color:#C00;font:700 11px Tahoma;background-color:#FCF;height:16px;width:30px;padding:0px;}\r\n.Danger0{background-color: #fff;}\r\n.Danger1{background-color: #fc6;}\r\n.Danger2{background-color: #9F9;}\r\n.Danger3{background-color: #9FF;}\r\n.Danger4{background-color: #BEA8FF;} \r\n.Danger5{background-color: #D6CD9E;} \r\n.Danger6{background-color: #FFF76F;} \r\n.Danger7{background-color: #FDC900;}\r\n.Danger99{background-color: #f96;}\r\n\r\n/*final balance*/\r\n.Button{border:1px solid #900; padding:2px 10px; font:700 12px Tahoma; background-color:#F99; cursor:pointer; }\r\n.Fail{ color:#F00; font-weight:700;}\r\n.Pass{ color:#008000; font-weight:700;}\r\n.BCEnable{ background-color:#dafff1;}\r\n.BCDisable{/*background-color:#f8ddea;*/ background-color:#DDD;}\r\n\r\n/*Form1 for product transfer*/\r\n.Form1{ border:2px solid #CCC; background:#FFF;}\r\n.Form1 caption{ font:700 12px/20px Tahoma; background:url(../images/caption_a.gif) no-repeat 2px 4px; padding:2px 0px 0px 22px; text-align:left; color:#fff;}\r\n.Form1 tbody th,.Form1 tbody td{ border-bottom:1px solid #EEE; padding:2px;}\r\n.Form1 tbody th{ text-align:right; vertical-align:top; line-height:22px;color:#036;}\r\n.Form1 tbody td{ vertical-align:middle;}\r\n.Form1 tfoot td{ text-align:left;}\r\n.InputForm1{font:12px Tahoma; background-color:#DCECFF; border:1px solid #CCC; height:18px; padding:0px 2px;}\r\n.TextareaForm1{font:12px Tahoma; background-color:#DCECFF; border:1px solid #CCC; height:80px; padding:0px 2px;}\r\n.ButtonForm1{font:700 14px Tahoma; background-color:#DCECFF; border:1px solid #000; height:20px; width:120px; padding:0px 2px; margin:4px 0px;}\r\n\r\n/*remarks*/\r\n.Remark{margin-top:20px; background:url(../images/icon-remark.gif) no-repeat; width:100%; margin-bottom:10px;}\r\n.RemarkT{font-weight:700; margin-bottom:10px; display:block; color:#933; padding-left:18px;}\r\n.Remark ul{list-style:disc; margin-bottom:5px;}\r\n.Remark ul ul{list-style:circle;}\r\n.Remark ul, .Remark ul ul{padding-left:10px; margin-left:10px;}\r\n.Remark li{padding:3px;}\r\n.Remark p{padding-left:18px;}\r\na.BackTop{background:url(../images/icon-back2top.png) no-repeat; font-size:11px; padding-left:17px; margin-top:5px; display:block; color:#00f;}\r\na:hover.BackTop{color:#F60;}\r\n.Note{ background:url(../images/icon-doublearrow.gif) no-repeat 5px 8px; border:1px dotted #c36; color:#900; font:700 11px Arial; padding:5px 2px 5px 18px;}\r\n\r\n/*release notes*/\r\n.ReleaseNote{margin-top:20px;}\r\n.ReleaseNote caption{background:url(../images/icon-calendar.png) no-repeat; font-weight:700; color:#933; padding-left:18px; text-align:left; height:25px;}\r\n.ReleaseNote th{width:90px; text-align:left; padding-left:18px;}\r\n.ReleaseNote th, .ReleaseNote td{height:20px;}\r\n\r\n/*RT Position Taking Expand Collapse*/\r\n.PositionTakingCountry{text-align:left; line-height:25px; background-color:#FFbbbb; padding:2px; border-bottom: 1px solid #EECACA;}\r\n.PositionTakingCountry .SectionSave{margin:2px 0 0 0;}\r\n.Collapse .PositionTakingCountryText{padding:2px 2px 2px 15px; background: url(../images/plus.gif) no-repeat 0 5px; cursor:pointer; margin-left:16px;}\r\n.Expand .PositionTakingCountryText{padding:2px 2px 2px 15px; background: url(../images/minus.gif) no-repeat 0 5px; cursor:pointer; margin-left:16px;}\r\n.Collapse .PositionTakingCountry{border-bottom: 1px solid #ffe1e1;}\r\n.Expand .PositionTakingCountry{border: none;}\r\n.Expand .PositionTakingContent{display:block;}\r\n.Collapse .PositionTakingContent{display:none;}\r\n\r\n/*Profile IOM*/\r\n.VerifyStatus{height:20px; float:left; padding-top:5px;}\r\n\r\n/*Company Risk*/\r\n.CompanyRiskTable thead tr td{height:30px; vertical-align:middle;}\r\n.CompanyRiskTable tbody tr td{text-align:center;}\r\n.RedBg{background-color:red; color:#fff;}\r\n.OrangeBg{background-color: #F90;}\r\n.YellowBg{background-color:#FF0;}\r\n\r\n.CompanyRiskTable tr:hover{background-color:#FFC;}\r\n\r\n/*Balance Status*/\r\n.BalStatus{padding:0px !important; margin:0px !important;}\r\n.BalStatus tbody td{border-right:1px solid #ffccff !important; padding-left:6px !important;}\r\n\r\n/*Max Entitlement and Max Requirement*/\r\n.MEMRTable thead td, .MEMRTable tbody td{border:none !important;}\r\n.MEMRTable thead td{background-color:transparent;}\r\n.AddTxt{float:right; padding-right:5px; font-size:11px !important; line-height:13px !important; color:#000; padding-top:2px;}\r\n\r\n/*new balance group page*/\r\n.SubTotalRow{background-color:#FFFFCC; }\r\n.BalanceTable tr:hover{background-color:#FFE6E6}\r\n.BalanceTable tr.SubTotalRow:hover{ background-color:#FFFFCC;}\r\n\r\n/*QuickTransfer Source Table*/\r\n.QuickTransferSourceTable{border-collapse: collapse; width: 100%;}\r\n.QuickTransferSourceTable thead th{ background-color:#FF9999; text-align:center; color:#000; font-weight:bold;}\r\n.QuickTransferSourceTable thead th.CheckColumn{width:30px;}\r\n.QuickTransferSourceTable tbody td{ text-align: center;}\r\n.QuickTransferSourceTable .TrSum{border: none !important;}\r\n\r\n\r\n/*Casino Balance Column*/\r\n.CasinoCol{position:relative; float:right;width:415px;}\r\n.CasinoHead,.CasinoVal{position:absolute;top:-6px;*top:-20px;padding:3px 2px;line-height:20px;}\r\n@-moz-document url-prefix() { .CasinoHead,.CasinoVal{top:-5px;}}\r\n@media all and (min-width:0) {.CasinoHead,.CasinoVal{ top:-5px \\0/; }}\r\n.CasinoHead{color:#C00;border-left:1px solid #ffccff;border-right:1px solid #ffccff;width:235px;text-align:right;}\r\n.CasinoVal{width:170px;right:0;}\r\n\r\n\r\n/*Casino Game Result Display*/\r\n\r\n.BetlistResultB{margin: 0 10px 0 0;width: 35px; float:left; color:#C00;}\r\n.BetlistResultP{margin: 0 10px 0 0;width: 35px; float:left; color:#00C;}\r\n\r\n/*.BetlistTable tbody td.VAM{ vertical-align:middle;}*/\r\n.ResultBaC,.ResultBaD,.ResultBaH,.ResultBaS{background:url(../images/betlist-card.gif) no-repeat; width:12px; height:16px; float:left; padding:0 6px 0 12px;}\r\n.ResultBaS{background-position:0px 1px;}\r\n.ResultBaH{background-position:0px -19px;}\r\n.ResultBaD{background-position:0px -39px;}\r\n.ResultBaC{background-position:0px -59px;}\r\n.ResultSB1,.ResultSB2,.ResultSB3,.ResultSB4,.ResultSB5,.ResultSB6{background:url(../images/betlist-dice.gif) no-repeat; height:34px; width:34px; float:left;}\r\n.ResultSB1{ background-position:0px 0px;}.ResultSB2{ background-position:-34px 0px;}.ResultSB3{ background-position:-68px 0px;}\r\n.ResultSB4{ background-position:-102px 0px;}.ResultSB5{ background-position:-136px 0px;}.ResultSB6{ background-position:-170px 0px;}\r\n\r\n.TrDivider{background-color:#b36666; color:#fff;}\r\n\r\n.LongCaption a, .Caption4 a{color:#fff000 !important;}"
          },
