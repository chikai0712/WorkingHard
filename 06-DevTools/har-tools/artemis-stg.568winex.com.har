            "text": "label { display: block; color: WindowText; background-color: Window; margin: 0; padding: 0; width: 100%; }\r\nlabel:hover { background-color: Highlight; color: HighlightText; }\r\n.permissionContainer { border:2px solid #ccc; width:100%; height:300px; overflow-y: scroll; }\r\n.permissionColumnList { margin: 0; padding-left: 5px; list-style-type: none; overflow-x: hidden; }\r\n\r\n.FixedButton {\r\n    position: fixed;\r\n    top: 100px;\r\n    left: 10px;\r\n}\r\n\r\nbody {\r\n\tmargin-left: 0px;\r\n\tmargin-top: 0px;\r\n\tmargin-right: 0px;\r\n\tmargin-bottom: 0px;\r\n}\r\n\r\n.PageHeader{\r\n\tfont-family:Tahoma;\r\n\tfont-size:18px;\r\n\tcolor:#be1e18;\r\n\tbackground-image:url(../images/headerIcon.gif);\r\n\tbackground-repeat:no-repeat;\r\n\tbackground-position: 0px 5px;\r\n\tpadding-left:20px;\r\n\tline-height:37px;\r\n}\r\n\r\n.QueryTable {\r\n\tborder: 2px solid #8d8d8d;\r\n\tborder-collapse:collapse;\r\n}\r\n\r\n.QueryTable Caption{\r\n\tbackground-image:url(../images/caption.gif);\r\n\tbackground-repeat:no-repeat;\r\n\tfont-family:Arial;\r\n\tfont-size:11px;\r\n\tfont-weight:700;\r\n\tcolor:#FFFFFF;\r\n\ttext-align:left;\r\n\theight:21px;\r\n\tpadding-left:10px;\r\n\tline-height: 18px;\r\n}\r\n\r\n\r\n.QueryTable td{\r\n\tborder: 1px solid #8a8a8a;\r\n\tpadding-left:5px;\r\n\tpadding-right:2px;\r\n\tpadding-top:3px;\r\n\tpadding-bottom:10px;\r\n\tbackground:#ffffff;\r\n}\r\n\r\n#tFoot{\r\npadding-top:15px;\r\ntext-align:center;\r\n}\r\n\r\n.ResultTable {\r\n\tborder: 2px solid #8d8d8d;\r\n\tborder-collapse:collapse;\r\n\tfont-family:Arial;\r\n\tfont-size:11px;\r\n\tfont-weight:700;\r\n}\r\n\r\n.ResultTable Caption{\r\n\tbackground-image:url(../images/caption.gif);\r\n\tbackground-repeat:no-repeat;\r\n\tcolor:#FFFFFF;\r\n\ttext-align:left;\r\n\theight:21px;\r\n\tpadding-left:10px;\r\n\tline-height: 18px;\r\n}\r\n\r\n.ResultTable th{\r\n\ttext-align:center;\r\n\tborder: 1px solid #8a8a8a;\r\n\tbackground-color:#d3c2c2;\r\n}\r\n\r\n.ResultTable td{\r\n\tfont-weight:normal;\r\n\tborder: 1px solid #8a8a8a;\r\n}\r\n\r\n.trOdd{\r\n\tbackground:#ecebeb;\r\n}\r\n\r\n.trEven{\r\n\tbackground:#fbfafa;\r\n}\r\n\r\n.FormInput{\r\n\tfont-family: Arial;\r\n\tfont-size: 11px;\r\n\tcolor: #000000;\r\n\tbackground-color: #ffffff;\r\n\tborder: 1px solid #7f9db9;\r\n\twidth:99%;\r\n\theight:100px;\r\n}\r\n\r\n.TextareaOutput{\r\n\tfont-family: Arial;\r\n\tfont-size: 11px;\r\n\tcolor: #000000;\r\n\tbackground-color: #ffffff;\r\n\tborder: 1px solid #7f9db9;\r\n\twidth:99%;\r\n\theight:300px;\r\n}\r\n\r\n.FormButton {\r\n\tfont-family: Arial;\r\n\tfont-size: 11px;\r\n\tpadding-left: 6px;\r\n\tpadding-right: 6px;\r\n\theight:20px;\r\n}\r\n"
