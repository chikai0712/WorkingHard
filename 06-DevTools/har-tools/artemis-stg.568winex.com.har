            "size": 4244,
            "mimeType": "text/css",
            "compression": 2584,
            "text": "/* CSS Document */\r\n/**/\r\n.B{font-weight:700 !important;}\r\n\r\n/*alignment*/\r\n.TAL{text-align:left !important;}\r\n.TAC{text-align:center !important;}\r\n.TAR{text-align:right !important;}\r\n.VAT{vertical-align:top !important;}\r\n.VAM{vertical-align:middle !important;}\r\n.VAB{vertical-align:bottom !important;}\r\n\r\n/*general*/\r\n.Cursor{cursor:pointer;}\r\n.Text{cursor:text;}\r\n\r\n/*border*/\r\n.Border0{border:0px !important;}\r\n.BorderRed{border:1px solid #F00 !important;}\r\n\r\n/*padding*/\r\n.Padding0{padding:0px !important;}\r\n.Padding4{padding:4px !important;}\r\n.PL4{padding-left:4px !important;}\r\n.PR5{padding-right:5px !important;}\r\n.PB4{padding-bottom:4px !important;}\r\n.PL12{padding-left:12px !important;}\r\n\r\n/*margin*/\r\n.Margin0{margin:0px !important;}\r\n.Margin4{margin:4px !important;}\r\n.MT4{margin-top:4px !important;}\r\n.MT10{margin-top:10px !important;}\r\n.MT20{margin-top:20px !important;}\r\n.MB4{margin-bottom:4px !important;}\r\n.ML20{margin-left: 20px;}\r\n.ML10{margin-left: 10px;}\r\n\r\n/*font*/\r\n.Arial{font-family:Arial !important;}\r\n.Tahoma{font-family:Tahoma !important;}\r\n.Font9, .FS9{font-size:9px !important;}\r\n.Font10, .FS10{font-size:10px !important;}\r\n.Font11, .FS11{font-size:11px !important; line-height:13px !important;}\r\n.Font12, .FS12{font-size:12px !important;}\r\n.Font14, .FS14{font-size:14px !important;}\r\n.Font16, .FS16{font-size:16px !important;}\r\n.FWN{font-weight:normal}\r\n.B{font-weight:700 !important;}\r\n.I{font-style:italic;}\r\n.U{text-decoration:underline !important;}\r\n.WSN{white-space:nowrap;}\r\n.Wrap{white-space:normal !important;}\r\n.BW{word-wrap:break-word;}\r\n.Break{word-break:break-all; word-wrap:break-word;}\r\n.FL{float:left !important;}\r\n.FR{float:right !important;}\r\n\r\na:link, a:visited, a:active{ text-decoration:none;}\r\na:hover{ color:#F60;}\r\n/* General */\r\n\r\n/* width */\r\n.W15{width:15px;}.W20{width:20px;}.W30{width:30px;}.W40{width:40px;}.W50{width:50px;}.W70{width:70px;}.W60{width:60px;}.W80{width:80px;}.W90{width:90px;}.W100{width:100px;}.W110{width:110px;}.W120{width:120px;}.W130{width:130px;}.W135{width:135px;}.W140{width:140px;}\r\n.W150{width:150px;}.W160{width:160px;}.W170{width:170px;}.W180{width:180px;}.W200{width:200px;}.W203{width:203px;}.W240{width:240px;}.W250{width:250px;}.W300{width:300px;}.W350{width:350px;}.W400{width:400px;}.W450{width:450px;}.W460{width:460px;}.W480{width:480px;}.W500{width:500px;}.W520{width:520px;}\r\n.W550{width:550px;}.W563{width:563px;}.W600{width:600px;}.W650{width:650px;}.W700{width:700px !important;}.W750{width:750px;}.W800{width:800px;}.W850{width:850px;}.W900{width:900px;}\r\n.W950{width:950px;}.W1000{width:1000px;}.W173{width:173px;}.W290{width:290px;}\r\n.W100P{ width:100%;}\r\n\r\n/* Height */\r\n.H25{height:25px;}\r\n.H30{height:30px;}\r\n.H50{height:50px;}.H60{height:60px;}.H70{height:70px;}.H80{height:80px;}.H90{height:90px;}.H100{height:100px;}\r\n\r\n/* Color */\r\n.Black{color:#000000;}\r\n.Blue{color:#0000FF;}\r\n.Brown{color:#A52A2A;}\r\n.DarkGreen{color:#006400;}\r\n.DarkRed{color:#8B0000;}\r\n.DimGray{color:#696969;}\r\n.Gray{color:#808080;}\r\n.Green{color:#008000;}\r\n.Maroon{color:#800000;}\r\n.MidnightBlue{color:#191970;}\r\n.Orange{ color:#FFA500;}\r\n.OrangeRed{color:#FF4500;}\r\n.Navy{ color:#000080;}\r\n.DarkOrange{color:#ED6F00;}\r\n.LGray{color:#999;}\r\n.BgDel td{background-color:#999;}\r\n.HeadBg td{background-color:#f99;}\r\n\r\n/*remarks*/\r\n.Remark{margin-top:20px; background:url(../images/icon-remark.gif) no-repeat; width:100%; margin-bottom:10px;}\r\n.RemarkT{font-weight:700; margin-bottom:10px; display:block; color:#933; padding-left:18px;}\r\n.Remark ul{list-style:disc; margin-bottom:5px;}\r\n.Remark ul ul{list-style:circle;}\r\n.Remark ul, .Remark ul ul{padding-left:10px; margin-left:10px;}\r\n.Remark li{padding:3px;}\r\n.Remark p{padding-left:18px;}\r\na.BackTop{background:url(../images/icon-back2top.png) no-repeat; font-size:11px; padding-left:17px; margin-top:5px; display:block; color:#00f;}\r\na:hover.BackTop{color:#F60;}\r\n.Note{ background:url(../images/icon-doublearrow.gif) no-repeat 5px 8px; border:1px dotted #c36; color:#900; font:700 11px Arial; padding:5px 2px 5px 18px;}\r\n\r\n/*End*/\r\n\r\na.BackPrev{background:url(../images/icon-back2prev.png) no-repeat; font-size:11px; padding-left:17px; margin-top:5px; display:block; color:#00f;}\r\na:hover.BackPrev{color:#F60;}"
