$TTL 300
$ORIGIN app.example.com.

@    IN    SOA    dns-secondary.app.example.com. admin.app.example.com. (
    2024010101 ; Serial (YYYYMMDDHH)
    3600       ; Refresh
    1800       ; Retry
    604800     ; Expire
    300        ; Minimum TTL
)

@    IN    NS    dns-secondary.app.example.com.

; A Record - Initially points to Main Service
app.example.com.    IN    A    172.20.0.20
