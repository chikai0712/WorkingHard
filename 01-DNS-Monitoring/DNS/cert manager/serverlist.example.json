{
  "servers": [
    {
      "name": "Web Server 1",
      "host": "192.168.1.100",
      "port": 22,
      "username": "root",
      "password": "your-password",
      "remote_path": "/etc/ssl/certs",
      "remote_dir": "example.com",
      "enabled": true
    },
    {
      "name": "Web Server 2",
      "host": "192.168.1.101",
      "port": 22,
      "username": "admin",
      "key_file": "~/.ssh/id_rsa",
      "remote_path": "/etc/ssl/certs",
      "remote_dir": "example.com",
      "enabled": true
    },
    {
      "name": "Load Balancer",
      "host": "lb.example.com",
      "port": 22,
      "username": "root",
      "key_file": "~/.ssh/id_rsa",
      "remote_path": "/etc/ssl/certs",
      "remote_dir": "example.com",
      "enabled": true
    },
    {
      "name": "Backup Server",
      "host": "backup.example.com",
      "port": 22,
      "username": "backup",
      "key_file": "~/.ssh/id_rsa",
      "remote_path": "/etc/ssl/certs",
      "remote_dir": "example.com",
      "enabled": false
    }
  ]
}

