# =====================================================
# 第三方監控服務 API 配置
# =====================================================

# ==================== ThousandEyes ====================
# 獲取方式：
# 1. 登入 https://app.thousandeyes.com
# 2. 點擊右上角頭像 → Account Settings
# 3. 選擇 "Users and Roles" → "Profile"
# 4. 找到 "OAuth Bearer Token" 或 "API Tokens"
# 5. 複製 Token

THOUSANDEYES_API_TOKEN=""

# 範例：
# THOUSANDEYES_API_TOKEN="abc123def456ghi789jkl012mno345pqr678stu901"


# ==================== Catchpoint ====================
# 獲取方式：
# 1. 登入 https://portal.catchpoint.com
# 2. 點擊 Settings → API
# 3. 創建新的 API Consumer
# 4. 複製 Client ID 和 Client Secret

CATCHPOINT_API_KEY=""
CATCHPOINT_API_SECRET=""

# 範例：
# CATCHPOINT_API_KEY="your-client-id-here"
# CATCHPOINT_API_SECRET="your-client-secret-here"


# ==================== Pingdom ====================
# 獲取方式：
# 1. 登入 https://my.pingdom.com
# 2. 點擊 Settings → Pingdom API
# 3. 創建新的 API Token
# 4. 複製 Token

PINGDOM_API_TOKEN=""

# 範例：
# PINGDOM_API_TOKEN="your-api-token-here"


# ==================== 測試配置 ====================
# 要測試的域名（可選）
TEST_DOMAIN=""

# 範例：
# TEST_DOMAIN="example.com"

# 測試間隔（秒）
TEST_INTERVAL=300

# 要監控的地區（用於篩選節點）
TARGET_REGIONS="VN,ID,SG,TH,PH"

# 範例：
# VN = Vietnam (越南)
# ID = Indonesia (印尼)
# SG = Singapore (新加坡)
# TH = Thailand (泰國)
# PH = Philippines (菲律賓)

