{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DB Ansible Consistency Summary",
  "type": "object",
  "required": [
    "event_id",
    "module",
    "device_family",
    "status",
    "summary",
    "updated_at"
  ],
  "properties": {
    "event_id": {"type": "string"},
    "module": {"const": "ansible"},
    "device_family": {"type": "string"},
    "status": {"type": "string", "enum": ["ok", "warning", "critical"]},
    "summary": {"type": "string"},
    "affected_devices": {"type": "array", "items": {"type": "string"}},
    "recommended_checks": {"type": "array", "items": {"type": "string"}},
    "recommended_policy": {"type": "string", "enum": ["pass", "hold", "block", "rollback", "fallback"]},
    "updated_at": {"type": "string"}
  }
}
