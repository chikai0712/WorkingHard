# ============================================================
# terraform.tfvars.example
# 複製此檔案為 terraform.tfvars 並填入真實值
# 注意：terraform.tfvars 已加入 .gitignore，不會進版控
# ============================================================

# ── GCP ──────────────────────────────────────────────────────
gcp_credentials_file = "./future-union-463404-t9-f3ce49c36a69.json"
gcp_project_id    = "future-union-463404-t9"
gcp_region        = "asia-northeast1"
gcp_zone          = "asia-northeast1-b"
gce_machine_type  = "e2-micro"
gce_instance_name = "test-web-server"

# ── AWS ──────────────────────────────────────────────────────
aws_region      = "ap-northeast-1"
domain_name     = "clouddeployment168.site"
subdomain       = "www"
route53_zone_id = "Z03781901VX21IK1MNF47"

# CloudFront 價格方案
# PriceClass_100 = 美洲 + 歐洲（最便宜）
# PriceClass_200 = 美洲 + 歐洲 + 亞太（推薦）
# PriceClass_All = 全球所有 Edge（最貴）
cloudfront_price_class = "PriceClass_200"
