# Copy this file to terraform.tfvars. The deploy script can create it for you.

aws_profile = "new-website"
aws_region  = "ap-northeast-1"

project_name  = "ec2-simple-website"
environment   = "dev"
instance_name = "cloudsite-simple-web"
instance_type = "t3.micro"

key_pair_name        = "cloudsite-new-website-key"
public_key_path      = "./cloudsite-new-website-key.pub"
ssh_private_key_path = "./cloudsite-new-website-key"

# Replace with your public IP CIDR, for example "203.0.113.10/32".
# The deploy script auto-detects this value.
ssh_allowed_cidr = "203.0.113.10/32"

domain_name = "clouddeployment168.site"
