# 複製此檔案為 terraform.tfvars 並填入你的實際值

aws_region = "ap-northeast-1"  # 或 "us-east-1"（CloudFront 證書必須在 us-east-1）

domain_name = "example.com"    # 改為你的域名

bucket_name = "example-com-website"  # S3 bucket 名稱（必須全球唯一）

# 如果需要 www 子域名
additional_domains = ["www.example.com"]

# 如果域名在 Route 53 管理，設為 true
# 如果域名在其他 DNS 提供商（如 Cloudflare、GoDaddy），設為 false
create_route53_zone = false

# CloudFront 價格等級
cloudfront_price_class = "PriceClass_100"
